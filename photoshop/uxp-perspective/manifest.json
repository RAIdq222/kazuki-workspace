{
  "id": "com.shouzen.perspective",
  "name": "パース線",
  "version": "0.1.0",
  "main": "index.html",
  "manifestVersion": 5,
  "host": {
    "app": "PS",
    "minVersion": "23.0.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "perspectivePanel",
      "label": { "default": "パース線" },
      "minimumSize": { "width": 320, "height": 360 },
      "maximumSize": { "width": 3000, "height": 3000 },
      "preferredDockedSize": { "width": 420, "height": 640 },
      "preferredFloatingSize": { "width": 1000, "height": 760 }
    }
  ],
  "requiredPermissions": {
    "localFileSystem": "plugin"
  },
  "icons": []
}
